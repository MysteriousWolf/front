# Rust build artifacts
/target/
**/*.rs.bk

# Cargo.lock is intentionally tracked (binary crate)

# Editor and IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
*.pem
*.key

# Claude Code local state
# NOTE: .claude/project/ (signals + followups) is deliberately tracked — CLAUDE.md
# @-refs the signals file and the followups index is auto-loaded each session.
# Only the disposable working dirs are ignored here.
.claude/settings.local.json
.claude/.scratchpad/
.claude/.atomic-index/
.sisyphus/

# Isolated worktrees created by the implement loop / autopilot
.worktrees/

# Ad-hoc experiments and scratch scripts
tmp/

# CLAUDE.md is intentionally tracked (project instructions)

# Runtime caches and logs (written to ~/.cache/front, but guard in-repo paths too)
*.log
*.log.*

# Test fixtures / large binary assets (GeoTIFF etc.)
*.tif
*.tiff
*.geotiff

# Profiling artefacts
perf.data
perf.data.old
flamegraph.svg
callgrind.out.*
massif.out.*

# Patch leftovers
*.orig
*.rej
